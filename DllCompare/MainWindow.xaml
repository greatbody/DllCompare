<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DllCompare.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DllCompare">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="3">
                <TextBlock Text="DLL Metadata Compare" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Drop two .NET DLLs to compare namespace, type, and method signature structure." Opacity="0.72" />
            </StackPanel>

            <Button x:Name="CompareButton" Grid.Column="1" Content="Compare" VerticalAlignment="Bottom" Click="CompareButton_Click" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Original" VerticalAlignment="Center" Width="70" />
                <TextBox x:Name="LeftPathTextBox" Grid.Column="1" PlaceholderText="Drop or select original .dll" IsReadOnly="True" AllowDrop="True" DragOver="DllPathTextBox_DragOver" Drop="LeftPathTextBox_Drop" />
                <Button Grid.Column="2" Content="Browse..." Click="BrowseLeftButton_Click" />
            </Grid>

            <Grid Grid.Column="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Rebuilt" VerticalAlignment="Center" Width="70" />
                <TextBox x:Name="RightPathTextBox" Grid.Column="1" PlaceholderText="Drop or select rebuilt .dll" IsReadOnly="True" AllowDrop="True" DragOver="DllPathTextBox_DragOver" Drop="RightPathTextBox_Drop" />
                <Button Grid.Column="2" Content="Browse..." Click="BrowseRightButton_Click" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" AllowDrop="True" DragOver="DllPathTextBox_DragOver" Drop="LeftPathTextBox_Drop">
                <Grid RowSpacing="8" Padding="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="LeftHeaderTextBlock" Text="Original" FontWeight="SemiBold" />
                    <TreeView x:Name="LeftTreeView" Grid.Row="1">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding Content}" />
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Summary" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusTextBlock" Text="Drop DLLs into the path boxes. When both sides are present, compare starts automatically." TextWrapping="Wrap" />
                    <StackPanel Spacing="6">
                        <TextBlock Text="Legend" FontWeight="SemiBold" />
                        <TextBlock Text="Green: added on rebuilt side" Foreground="ForestGreen" />
                        <TextBlock Text="Red: removed from rebuilt side" Foreground="Firebrick" />
                        <TextBlock Text="Gray: unchanged" Opacity="0.72" />
                    </StackPanel>
                    <TextBlock x:Name="CountsTextBlock" FontFamily="Consolas" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" AllowDrop="True" DragOver="DllPathTextBox_DragOver" Drop="RightPathTextBox_Drop">
                <Grid RowSpacing="8" Padding="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="RightHeaderTextBlock" Text="Rebuilt" FontWeight="SemiBold" />
                    <TreeView x:Name="RightTreeView" Grid.Row="1">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding Content}" />
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
